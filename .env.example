# LLM Configuration
OLLAMA_HOST=http://localhost:11434
CLAUDE_API_KEY=your_anthropic_api_key_here

# Database Configuration
SQLITE_PATH=./data/adler.db
DB_ENCRYPTION_KEY=your_secure_encryption_key_here

# Voice Configuration
WAKE_WORD_MODEL=hey_adler.ppn
VOSK_MODEL_PATH=./models/vosk-model-small-tr-0.3
PIPER_VOICE_PATH=./models/tr_TR-fatih-medium.onnx
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Market / API Keys
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Hardware
HARDWARE_ENABLED=false
GPIO_PIN_MAP_FILE=./config/pins.yaml

# General
LOG_LEVEL=info
RUST_LOG=info,adler_asi=debug
